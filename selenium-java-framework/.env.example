# ================================================================
# Perfex CRM — Automation Framework Configuration
# ================================================================
# Copy file này thành config.properties và điền giá trị thực
# File config.properties đã được thêm vào .gitignore
# ================================================================

# ---- Application URL ----
base.url=https://crm.anhtester.com/admin/authentication

# ---- Admin Credentials (demo account) ----
# CAUTION: Không commit credentials thực lên Git
admin.email=admin@example.com
admin.password=your_password_here

# ---- Browser Settings ----
# Giá trị: chrome | firefox | edge
browser=chrome

# Chạy headless (true cho CI/CD, false để debug trên UI)
headless=false

# ---- Timeouts (seconds) ----
implicit.wait.seconds=10
explicit.wait.seconds=15
page.load.timeout.seconds=30

# ---- Screenshot ----
# Thư mục lưu screenshot khi test FAIL
screenshot.dir=target/screenshots

# ---- Allure ----
allure.results.dir=target/allure-results
