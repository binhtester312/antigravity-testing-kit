{
  "name": "playwright-typescript-framework",
  "version": "1.0.0",
  "description": "E2E Web UI Automation Framework — Playwright Test + TypeScript (Strict Mode)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:security": "playwright test --grep @security",

    "report:playwright": "playwright show-report",
    "report:playwright:json": "cat test-results/results.json",

    "allure:clean": "rimraf allure-results allure-report",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",

    "test:allure": "playwright test && npm run allure:generate && npm run allure:open",
    "test:allure:chromium": "playwright test --project=chromium && npm run allure:generate && npm run allure:open",
    "test:allure:smoke": "playwright test --grep @smoke && npm run allure:generate && npm run allure:open",
    "test:allure:ci": "playwright test && npm run allure:generate",

    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf playwright-report test-results allure-results allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "dotenv": "^16.4.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
