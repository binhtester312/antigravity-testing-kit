# ===========================================
# n_framework — Environment Variables Template
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên Git
# ===========================================

# --- Application URLs ---
BASE_URL=https://your-app-url.com
API_BASE_URL=https://your-api-url.com

# --- Environment ---
# Giá trị: dev | staging | prod
ENV=staging

# --- Test Credentials (dùng cho default test user) ---
DEFAULT_USERNAME=testuser@example.com
DEFAULT_PASSWORD=TestPassword@123

# --- Browser Config ---
# Giá trị: chromium | firefox | webkit
BROWSER=chromium
HEADLESS=true

# --- Timeouts (milliseconds) ---
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000

# --- Retry ---
TEST_RETRY_COUNT=1

# --- Report ---
REPORT_DIR=playwright-report
